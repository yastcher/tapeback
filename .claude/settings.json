{
  "showThinkingSummaries": true,
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch(domain:*)",
      "Bash(ls *)",
      "Bash(uv sync*)",
      "Bash(uv run jupyter*)",
      "Bash(uv run python*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv pip:*)",
      "Bash(python*)",
      "Bash(*tapeback/.venv/bin/python*)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(head*)",
      "Bash(git * diff *)",
      "Bash(git * status *)",
      "Bash(git * log *)",
      "Bash(git * ls-files *)",
      "Bash(git * show *)",
      "Bash(docker ps:*)",
      "Bash(nvidia-smi:*)"
