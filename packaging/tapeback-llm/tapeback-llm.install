_venv=/opt/tapeback

post_install() {
    echo "==> Installing LLM dependencies into tapeback venv..."
    "$_venv/bin/pip" install --no-cache-dir "anthropic>=0.40.0" "openai>=1.50.0"
    echo "==> Done. Set an API key to enable summarization:"
    echo "    ANTHROPIC_API_KEY, OPENAI_API_KEY, GEMINI_API_KEY, etc."
    echo "    See: https://github.com/yastcher/echo-vault#llm-summarization"
}

post_upgrade() {
    post_install
}

pre_remove() {
    echo "==> Removing LLM dependencies from tapeback venv..."
    "$_venv/bin/pip" uninstall -y anthropic openai 2>/dev/null || true
}
